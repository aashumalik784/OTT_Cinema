{
  "name": "ott-cinema",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OTT Cinema - Movie streaming app built with Vite + React + TailwindCSS",
  "author": {
    "name": "aashumalik784",
    "email": "aashumalik784@gmail.com",
    "url": "https://github.com/aashumalik784"
  },
  "license": "MIT",
  "homepage": "https://ott-cinema.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aashumalik784/OTT_Cinema.git"
  },
  "bugs": {
    "url": "https://github.com/aashumalik784/OTT_Cinema/issues",
    "email": "aashumalik784@gmail.com"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/aashumalik784"
  },
  "keywords": [
    "ott",
    "cinema",
    "movies",
    "streaming",
    "react",
    "vite",
    "tailwindcss",
    "tmdb",
    "netflix-clone",
    "movie-app",
    "video-player",
    "responsive",
    "pwa",
    "spa",
    "frontend",
    "typescript",
    "javascript",
    "cloudflare",
    "cloudflare-pages",
    "modern-ui"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=1.22.0",
    "pnpm": ">=8.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "main": "src/main.jsx",
  "module": "src/main.jsx",
  "browser": "src/main.jsx",
  "types": "src/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite --host --port 3000",
    "start": "vite --host --port 3000",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:staging": "vite build --mode staging",
    "build:prod": "vite build --mode production",
    "preview": "vite preview --port 4173",
    "preview:https": "vite preview --https",
    "serve": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:css": "stylelint **/*.{css,scss}",
    "lint:css:fix": "stylelint **/*.{css,scss} --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "prepush": "npm run type-check && npm run test:run",
    "clean": "rimraf dist coverage .turbo node_modules/.cache",
    "clean:all": "rimraf dist coverage .turbo node_modules package-lock.json",
    "reinstall": "npm run clean:all && npm install",
    "update": "npx npm-check-updates -u && npm install",
    "update:major": "npx npm-check-updates -u --target major && npm install",
    "analyze": "vite build --mode analyze",
    "analyze:bundle": "npx vite-bundle-visualizer",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "npm run build && wrangler pages deploy dist",
    "cf:deploy:prod": "npm run build:prod && wrangler pages deploy dist --project-name=ott-cinema",
    "gen:icons": "pwa-asset-generator",
    "gen:types": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changelog": "auto-changelog -p",
    "release": "release-it",
    "release:major": "release-it major",
    "release:minor": "release-it minor",
    "release:patch": "release-it patch"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "axios": "^1.6.7",
    "@tanstack/react-query": "^5.17.19",
    "zustand": "^4.5.0",
    "react-hook-form": "^7.49.3",
    "zod": "^3.22.4",
    "@hookform/resolvers": "^3.3.4",
    "react-icons": "^5.0.1",
    "react-hot-toast": "^2.4.1",
    "react-player": "^2.14.1",
    "swiper": "^11.0.6",
    "framer-motion": "^11.0.3",
    "react-lazy-load-image-component": "^1.6.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-select": "^5.8.0",
    "react-datepicker": "^6.1.0",
    "date-fns": "^3.3.1",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.314.0",
    "react-use": "^17.5.0",
    "usehooks-ts": "^3.0.1",
    "react-error-boundary": "^4.0.13",
    "react-helmet-async": "^2.0.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-import": "^2.29.1",
    "postcss": "^8.4.33",
    "postcss-import": "^16.0.0",
    "postcss-nesting": "^12.1",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "stylelint": "^16.2.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-pwa": "^0.17.4",
    "vite-plugin-svgr": "^4.2.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.2.2",
    "@vitest/ui": "^1.2.2",
    "@vitest/coverage-v8": "^1.2.2",
    "jsdom": "^24.0.0",
    "@testing-library/react": "^14.2.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/user-event": "^14.5.2",
    "@playwright/test": "^1.41.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "rimraf": "^5.0.5",
    "wrangler": "^3.28.1",
    "workbox-window": "^7.0",
    "sharp": "^0.33.2",
    "vite-bundle-visualizer": "^0.8.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "@storybook/react": "^7.6.13",
    "@storybook/react-vite": "^7.6.13",
    "storybook": "^7.6.13",
    "auto-changelog": "^2.4.0",
    "release-it": "^17.1.1",
    "@release-it/conventional-changelog": "^8.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.1",
    "npm-check-updates": "^16.14.12"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "resolutions": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "es2020": true,
      "node": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:react-hooks/recommended",
      "plugin:react/recommended",
      "plugin:react/jsx-runtime",
      "plugin:jsx-a11y/recommended",
      "plugin:import/recommended",
      "plugin:import/typescript",
      "prettier"
    ],
    "ignorePatterns": [
      "dist",
      ".eslintrc.cjs",
      "vite.config.ts",
      "coverage",
      "storybook-static"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      },
      "project": "./tsconfig.json"
    },
    "plugins": [
      "react-refresh",
      "@typescript-eslint",
      "react",
      "jsx-a11y",
      "import"
    ],
    "rules": {
      "react-refresh/only-export-components": ["warn", { "allowConstantExport": true }],
      "react/prop-types": "off",
      "react/react-in-jsx-scope": "off",
      "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-function-return-type": "off",
      "@typescript-eslint/explicit-module-boundary-types": "off",
      "no-console": ["warn", { "allow": ["warn", "error"] }],
      "import/order": ["error", {
        "groups": ["builtin", "external", "internal", "parent", "sibling", "index"],
        "newlines-between": "always"
      }]
    },
    "settings": {
      "react": {
        "version": "detect"
      },
      "import/resolver": {
        "typescript": {
          "alwaysTryTypes": true
        }
      }
    }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all", "not ie 11"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version", "last 1 edge version"]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{css,scss}": ["stylelint --fix", "prettier --write"],
    "*.{json,md}": ["prettier --write"]
  },
  "stylelint": {
    "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
    "rules": {
      "at-rule-no-unknown": [true, { "ignoreAtRules": ["tailwind", "apply", "variants", "responsive", "screen"] }]
    }
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.4.0"
  },
  "packageManager": "npm@10.4.0",
  "pnpm": {
    "overrides": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    }
  }
}
